# Repository secrets for the gh-aw policy reviewer workflows.
# Configure these in GitHub repository settings:
# https://github.com/jbaruch/kotlin-tutor/settings/secrets/actions
#
# Required: ANTHROPIC_API_KEY, TESSL_TOKEN, and one of OPENAI_API_KEY or
# CODEX_API_KEY (the OpenAI workflow accepts either as the engine credential).
# OPENAI_API_KEY / CODEX_API_KEY and ANTHROPIC_API_KEY are validated fail-fast
# by each reviewer's `activation` job; TESSL_TOKEN is consumed later, by the
# `tessl install` setup step inside the agent job, so a missing value surfaces
# only once the agent job starts.

# OpenAI billing account for the Codex reviewer (`PR Policy Review (OpenAI)`).
# `CODEX_API_KEY` is accepted as an alternative name by the OpenAI workflow.
OPENAI_API_KEY=__REPLACE_ME__

# Anthropic billing account for the Claude Code reviewer (`PR Policy Review (Anthropic)`).
ANTHROPIC_API_KEY=__REPLACE_ME__

# Tessl registry token, used by the reviewer workflows' `tessl install` setup step.
# Generate at https://tessl.io/account/api-keys
TESSL_TOKEN=__REPLACE_ME__
