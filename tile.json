{
  "name": "jbaruch/kotlin-tutor",
  "version": "0.3.0",
  "summary": "Teaches AI agents to write idiomatic Kotlin instead of Java-in-a-.kt-file.",
  "private": false,
  "entrypoint": "README.md",
  "keywords": [
    "kotlin",
    "idioms",
    "kotest",
    "data-class",
    "agents",
    "quality"
  ],
  "skills": {
    "kotlinify-tests": {
      "path": "skills/kotlinify-tests/SKILL.md"
    },
    "pojoify-to-dataclass": {
      "path": "skills/pojoify-to-dataclass/SKILL.md"
    },
    "nullable-cleanup": {
      "path": "skills/nullable-cleanup/SKILL.md"
    }
  },
  "steering": {
    "prefer-val": {
      "rules": "rules/prefer-val.md",
      "alwaysApply": true
    },
    "nullable-question-mark": {
      "rules": "rules/nullable-question-mark.md",
      "alwaysApply": true
    },
    "use-data-class": {
      "rules": "rules/use-data-class.md",
      "alwaysApply": true
    },
    "kotest-over-junit": {
      "rules": "rules/kotest-over-junit.md",
      "alwaysApply": true
    },
    "prefer-stdlib-scope": {
      "rules": "rules/prefer-stdlib-scope.md",
      "alwaysApply": true
    },
    "extension-over-util": {
      "rules": "rules/extension-over-util.md",
      "alwaysApply": true
    }
  }
}
